# Deny all direct access to files in this directory

# Apache 2.2 with mod_access_compat
<IfModule mod_access_compat.c>
    Order deny,allow
    Deny from all
</IfModule>

# Apache 2.4 native (used when mod_access_compat is not available)
<IfModule !mod_access_compat.c>
    <RequireAll>
        Require all denied
    </RequireAll>
</IfModule>
